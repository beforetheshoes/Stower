// Tests.xcconfig
// Standalone config for the UI test target. Does NOT include
// Shared.xcconfig — inheriting the main app's entitlements, background
// modes, and iCloud settings causes Xcode to request capabilities that
// the test target's App ID doesn't have, which breaks automatic signing.

// ==========================================
// Deployment targets (must match Shared.xcconfig)
// ==========================================
IPHONEOS_DEPLOYMENT_TARGET = 26.0
MACOSX_DEPLOYMENT_TARGET = 26.0

// ==========================================
// Test Target Identity
// ==========================================
PRODUCT_NAME = StowerUITests
PRODUCT_BUNDLE_IDENTIFIER = com.ryanleewilliams.stower.uitests

// ==========================================
// Code Coverage
// ==========================================
CLANG_ENABLE_CODE_COVERAGE = YES
GCC_GENERATE_TEST_COVERAGE_FILES = YES
GCC_INSTRUMENT_PROGRAM_FLOW_ARCS = YES