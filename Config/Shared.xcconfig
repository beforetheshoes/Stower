// Shared.xcconfig
// Single dual-platform configuration used by both iOS and macOS builds of
// the unified `Stower` target. Values that apply to both platforms live at
// the top; SDK-conditional values live at the bottom.

// ==========================================
// Project Identity
// ==========================================
PRODUCT_NAME = Stower
PRODUCT_DISPLAY_NAME = Stower
PRODUCT_BUNDLE_IDENTIFIER = com.ryanleewilliams.stower
MARKETING_VERSION = 0.4.1
CURRENT_PROJECT_VERSION = 10
STOWER_URL_SCHEME = stower

// ==========================================
// Platform Configuration
// ==========================================
IPHONEOS_DEPLOYMENT_TARGET = 27.0
MACOSX_DEPLOYMENT_TARGET = 27.0

// (1 == iPhone, 2 == iPad) — ignored on macOS
TARGETED_DEVICE_FAMILY = 1,2

// ==========================================
// Info PLIST — iOS keys are ignored on macOS, mac-only keys on iOS
// ==========================================
GENERATE_INFOPLIST_FILE = YES
INFOPLIST_KEY_UISupportedInterfaceOrientations = portrait portrait-upside-down landscape-left landscape-right
INFOPLIST_KEY_UISupportedInterfaceOrientations_iPad = portrait landscape-left landscape-right portrait-upside-down

// Background modes for CloudKit (iOS only — ignored on macOS)
INFOPLIST_KEY_UIBackgroundModes = remote-notification background-processing

// macOS App Store category (ignored on iOS)
INFOPLIST_KEY_LSApplicationCategoryType = public.app-category.productivity

// Privacy usage descriptions
INFOPLIST_KEY_NSUserNotificationsUsageDescription = Stower uses notifications to inform you when articles are processed and ready to read.

// ==========================================
// Build Settings
// ==========================================
ALWAYS_SEARCH_USER_PATHS = NO
ALWAYS_USE_SEPARATE_HEADERMAPS = YES

// ==========================================
// Entitlements — SDK-conditional
// ==========================================
// Default (iOS) entitlements — catches iphoneos and iphonesimulator SDKs.
CODE_SIGN_ENTITLEMENTS = Config/Stower.entitlements
// Override for macOS builds — adds App Sandbox + Hardened Runtime and
// drops iOS-only keys like aps-environment.
CODE_SIGN_ENTITLEMENTS[sdk=macosx*] = Config/Stower-macOS.entitlements
